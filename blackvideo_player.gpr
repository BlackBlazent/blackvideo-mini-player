-- blackvideo_player.gpr  v2.4
-- Ada project file. C files compiled separately by build.bat / build.sh.
-- New in v2.4: process_helpers.o, thumb_preview_c.o, llm_client_c.o
--              linker: -lwininet (Windows only)

project BlackVideo_Player is

   type OS_Kind is ("windows", "linux", "macos");
   OS : OS_Kind := external ("OS_TARGET", "windows");

   for Source_Dirs use (
      "src",
      "bindings/ffmpeg",
      "bindings/sdl2"
   );

   for Languages use ("Ada");   -- C compiled separately

   for Object_Dir use "build/obj";
   for Exec_Dir   use "build";
   for Main       use ("main.adb");

   -- ── Compiler ──────────────────────────────────────────────────────────
   package Compiler is
      for Default_Switches ("Ada") use (
         "-g", "-O2", "-gnat2012", "-gnatwa", "-gnatQ"
      );
   end Compiler;

   -- ── Linker ────────────────────────────────────────────────────────────
   package Linker is
      case OS is
         when "windows" =>
            for Switches ("Ada") use (
               project'Project_Dir & "build/obj/ffmpeg_helpers.o",
               project'Project_Dir & "build/obj/ui_overlay_c.o",
               project'Project_Dir & "build/obj/process_helpers.o",
               project'Project_Dir & "build/obj/thumb_preview_c.o",
               project'Project_Dir & "build/obj/llm_client_c.o",
               project'Project_Dir & "resources/blackvideo.o",
               "-L" & project'Project_Dir & "lib",
               "-lSDL2main",
               "-l:libSDL2_ttf.dll.a",
               "-lSDL2",
               "-lavcodec", "-lavformat", "-lavutil",
               "-lswscale", "-lswresample",
               "-lwininet",
               "-lwindowscodecs", "-lole32", "-loleaut32", "-lwinmm",
               "-lversion", "-limm32", "-lsetupapi", "-luuid",
               "-lgdi32", "-lusp10", "-lrpcrt4",
               "-Wl,--subsystem,console"
            );
         when "linux" =>
            for Switches ("Ada") use (
               project'Project_Dir & "build/obj/ffmpeg_helpers.o",
               project'Project_Dir & "build/obj/ui_overlay_c.o",
               project'Project_Dir & "build/obj/process_helpers.o",
               project'Project_Dir & "build/obj/thumb_preview_c.o",
               project'Project_Dir & "build/obj/llm_client_c.o",
               "-L" & project'Project_Dir & "lib",
               "-lSDL2_ttf", "-lSDL2",
               "-lavcodec", "-lavformat", "-lavutil",
               "-lswscale", "-lswresample",
               "-lpthread", "-ldl", "-lm"
            );
         when "macos" =>
            for Switches ("Ada") use (
               project'Project_Dir & "build/obj/ffmpeg_helpers.o",
               project'Project_Dir & "build/obj/ui_overlay_c.o",
               project'Project_Dir & "build/obj/process_helpers.o",
               project'Project_Dir & "build/obj/thumb_preview_c.o",
               project'Project_Dir & "build/obj/llm_client_c.o",
               "-L" & project'Project_Dir & "lib",
               "-lSDL2_ttf", "-lSDL2",
               "-lavcodec", "-lavformat", "-lavutil",
               "-lswscale", "-lswresample",
               "-framework", "CoreFoundation",
               "-framework", "AudioToolbox",
               "-framework", "CoreVideo",
               "-framework", "Cocoa"
            );
      end case;
   end Linker;

   -- ── Builder ───────────────────────────────────────────────────────────
   package Builder is
      for Executable ("main.adb") use "blackvideo-player";
      for Default_Switches ("Ada") use ("-j0");
   end Builder;

   package IDE is
      for VCS_Kind use "Git";
   end IDE;

end BlackVideo_Player;
